<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="matomo_daily_metric_search_view" model="ir.ui.view">
        <field name="name">matomo.daily.metric.search</field>
        <field name="model">matomo.daily.metric</field>
        <field name="arch" type="xml">
            <search>
                <field name="instance_id" />
                <field name="date" />
                <filter name="group_by_date" string="Date" context="{'group_by': 'date'}" />
                <filter name="group_by_instance" string="Connection" context="{'group_by': 'instance_id'}" />
            </search>
        </field>
    </record>

    <record id="matomo_daily_metric_tree_view" model="ir.ui.view">
        <field name="name">matomo.daily.metric.tree</field>
        <field name="model">matomo.daily.metric</field>
        <field name="arch" type="xml">
            <list>
                <field name="date" />
                <field name="instance_id" />
                <field name="visitors" />
                <field name="sessions" />
                <field name="conversions" />
                <field name="bounce_rate" />
                <field name="avg_session_duration" />
                <field name="top_channel" />
            </list>
        </field>
    </record>

    <record id="matomo_daily_metric_graph_view" model="ir.ui.view">
        <field name="name">matomo.daily.metric.graph</field>
        <field name="model">matomo.daily.metric</field>
        <field name="arch" type="xml">
            <graph string="Daily Traffic Trend" type="line">
                <field name="date" interval="day" />
                <field name="sessions" type="measure" />
                <field name="visitors" type="measure" />
                <field name="conversions" type="measure" />
            </graph>
        </field>
    </record>

    <record id="matomo_daily_metric_pivot_view" model="ir.ui.view">
        <field name="name">matomo.daily.metric.pivot</field>
        <field name="model">matomo.daily.metric</field>
        <field name="arch" type="xml">
            <pivot string="Daily Metrics">
                <field name="date" type="row" interval="day" />
                <field name="instance_id" type="col" />
                <field name="visitors" type="measure" />
                <field name="sessions" type="measure" />
                <field name="conversions" type="measure" />
            </pivot>
        </field>
    </record>

    <record id="matomo_daily_metric_action" model="ir.actions.act_window">
        <field name="name">Daily Trend</field>
        <field name="res_model">matomo.daily.metric</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="matomo_daily_metric_search_view" />
    </record>

